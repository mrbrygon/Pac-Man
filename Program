import javax.swing.*;

public class Program extends JFrame{
	
	private static final long serialVersionUID = 1L;

	public Program() {
		
		this.setTitle("Pacman");
		this.setResizable(false);

		Wall maze = new Wall();
		
		this.add(maze);
		
